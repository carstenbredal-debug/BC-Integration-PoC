@page "/"
@using web.Models
@using web.Services
@inject BcApiService Api

<PageTitle>Create Customer</PageTitle>

<h1>Create Customer in Business Central</h1>

<div class="card">
    <div class="card-body">
        <EditForm Model="@_model" OnValidSubmit="HandleSubmit" FormName="CreateCustomer">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label" for="displayName">Display Name *</label>
                <InputText id="displayName" class="form-control" @bind-Value="_model.DisplayName" />
                <ValidationMessage For="@(() => _model.DisplayName)" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="_model.Email" />
                <ValidationMessage For="@(() => _model.Email)" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="phone">Phone Number</label>
                <InputText id="phone" class="form-control" @bind-Value="_model.PhoneNumber" />
                <ValidationMessage For="@(() => _model.PhoneNumber)" />
            </div>

            <hr />
            <h5>Address</h5>

            <div class="mb-3">
                <label class="form-label" for="address">Street Address</label>
                <InputText id="address" class="form-control" @bind-Value="_model.AddressLine1" />
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label" for="postalCode">Postal Code</label>
                    <InputText id="postalCode" class="form-control" @bind-Value="_model.PostalCode" />
                </div>
                <div class="col-md-8">
                    <label class="form-label" for="city">City</label>
                    <InputText id="city" class="form-control" @bind-Value="_model.City" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="country">Country/Region</label>
                @if (_loadingDropdowns)
                {
                    <div class="d-flex align-items-center">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Loading...</span>
                    </div>
                }
                else
                {
                    <InputSelect id="country" class="form-select" @bind-Value="_model.Country">
                        <option value="">-- Select country --</option>
                        @foreach (var c in _countries)
                        {
                            <option value="@c.Code">@c.DisplayName (@c.Code)</option>
                        }
                    </InputSelect>
                }
            </div>

            <hr />
            <h5>Posting Setup</h5>

            <div class="mb-3">
                <label class="form-label" for="paymentTerms">Payment Terms</label>
                @if (_loadingDropdowns)
                {
                    <div class="d-flex align-items-center">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Loading...</span>
                    </div>
                }
                else
                {
                    <InputSelect id="paymentTerms" class="form-select" @bind-Value="_model.PaymentTermsId">
                        <option value="">-- Select payment terms --</option>
                        @foreach (var pt in _paymentTerms)
                        {
                            <option value="@pt.Id">@pt.DisplayName (@pt.Code)</option>
                        }
                    </InputSelect>
                }
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="genBusPostingGroup">Gen. Bus. Posting Group</label>
                    @if (_loadingDropdowns)
                    {
                        <div class="d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Loading...</span>
                        </div>
                    }
                    else
                    {
                        <InputSelect id="genBusPostingGroup" class="form-select" @bind-Value="_model.GenBusPostingGroup">
                            <option value="">-- Select --</option>
                            @foreach (var g in _genBusPostingGroups)
                            {
                                <option value="@g.Code">@g.Code</option>
                            }
                        </InputSelect>
                    }
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="vatBusPostingGroup">VAT Bus. Posting Group</label>
                    @if (_loadingDropdowns)
                    {
                        <div class="d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Loading...</span>
                        </div>
                    }
                    else
                    {
                        <InputSelect id="vatBusPostingGroup" class="form-select" @bind-Value="_model.VatBusPostingGroup">
                            <option value="">-- Select --</option>
                            @foreach (var g in _vatBusPostingGroups)
                            {
                                <option value="@g.Code">@g.Code</option>
                            }
                        </InputSelect>
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-primary" disabled="@_submitting">
                @if (_submitting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <text>Creating...</text>
                }
                else
                {
                    <text>Create Customer</text>
                }
            </button>
        </EditForm>

        @if (_result is not null)
        {
            <div class="alert @(_result.Failed > 0 ? "alert-danger" : "alert-success") mt-3" role="alert">
                @if (_result.Failed > 0)
                {
                    <strong>Failed.</strong>
                    @foreach (var error in _result.Errors)
                    {
                        <p class="mb-0">@error</p>
                    }
                }
                else if (_result.Created > 0)
                {
                    <strong>Customer created successfully in Business Central.</strong>
                }
                else if (_result.Updated > 0)
                {
                    <strong>Customer already existed and was updated in Business Central.</strong>
                }
            </div>
        }

        @if (_errorMessage is not null)
        {
            <div class="alert alert-danger mt-3" role="alert">
                <strong>Error:</strong> @_errorMessage
            </div>
        }
    </div>
</div>

@code {
    private CreateCustomerRequest _model = new();
    private SyncResult? _result;
    private string? _errorMessage;
    private bool _submitting;
    private bool _loadingDropdowns = true;
    private List<CountryRegion> _countries = new();
    private List<PaymentTerm> _paymentTerms = new();
    private List<PostingGroup> _genBusPostingGroups = new();
    private List<PostingGroup> _vatBusPostingGroups = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tasks = new[]
            {
                LoadAsync(async () => _countries = await Api.GetCountriesRegionsAsync()),
                LoadAsync(async () => _paymentTerms = await Api.GetPaymentTermsAsync()),
                LoadAsync(async () => _genBusPostingGroups = await Api.GetGenBusPostingGroupsAsync()),
                LoadAsync(async () => _vatBusPostingGroups = await Api.GetVatBusPostingGroupsAsync())
            };
            await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load dropdown data: {ex.Message}";
        }
        finally
        {
            _loadingDropdowns = false;
        }
    }

    private static async Task LoadAsync(Func<Task> action)
    {
        await action();
    }

    private async Task HandleSubmit()
    {
        _submitting = true;
        _result = null;
        _errorMessage = null;

        try
        {
            _result = await Api.CreateCustomerAsync(_model);

            if (_result.Failed == 0)
            {
                _model = new CreateCustomerRequest();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
}
